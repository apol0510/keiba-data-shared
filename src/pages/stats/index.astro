---
/**
 * 的中率ダッシュボード - 予想成績統計ページ
 */

import { readFileSync } from 'fs';
import { join } from 'path';

const title = '馬単予想成績統計 - KEIBA Intelligence 馬単的中率・回収率ダッシュボード';
const description = '南関競馬の馬単予想成績を公開。馬単的中率45.2%、回収率339.2%の実績データ。競馬場別成績も確認できます。';

// 統計データ読み込み
let stats = null;
try {
  const statsPath = join(process.cwd(), 'stats', 'nankan-stats.json');
  const statsData = readFileSync(statsPath, 'utf-8');
  stats = JSON.parse(statsData);
} catch (error) {
  console.error('統計データ読み込みエラー:', error);
}

// 生成日時のフォーマット
function formatDateTime(isoString: string) {
  const date = new Date(isoString);
  return `${date.getFullYear()}年${date.getMonth() + 1}月${date.getDate()}日 ${date.getHours()}:${String(date.getMinutes()).padStart(2, '0')}`;
}
---

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{title}</title>
  <meta name="description" content={description}>

  <!-- SEO -->
  <meta name="keywords" content="競馬,予想,的中率,回収率,南関競馬,大井,川崎,船橋,浦和,統計,成績">
  <link rel="canonical" href={`${Astro.site}stats/`}>

  <!-- OGP -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content="website">
  <meta property="og:url" content={`${Astro.site}stats/`}>

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Hiragino Sans', 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif;
      line-height: 1.6;
      color: #2C3E50;
      background: linear-gradient(135deg, #FFD700 0%, #FFA500 25%, #FF69B4 50%, #9B59B6 75%, #3498DB 100%);
      background-size: 400% 400%;
      animation: gradientShift 15s ease infinite;
      background-attachment: fixed;
      min-height: 100vh;
    }

    @keyframes gradientShift {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    /* ヘッダー */
    header {
      background: linear-gradient(135deg, #FF6B6B 0%, #FFD93D 25%, #6BCB77 50%, #4D96FF 75%, #9B59B6 100%);
      background-size: 200% 200%;
      animation: headerGradient 10s ease infinite;
      color: white;
      padding: 3rem 1rem;
      box-shadow: 0 8px 32px rgba(255, 215, 0, 0.5);
      position: relative;
      overflow: hidden;
    }

    @keyframes headerGradient {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    header::before {
      content: '📊';
      position: absolute;
      font-size: 15rem;
      opacity: 0.15;
      right: -2rem;
      top: -3rem;
      transform: rotate(-15deg);
      animation: floatEmoji 6s ease-in-out infinite;
    }

    @keyframes floatEmoji {
      0%, 100% { transform: rotate(-15deg) translateY(0); }
      50% { transform: rotate(-15deg) translateY(-20px); }
    }

    .header-content {
      max-width: 1200px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    h1 {
      font-size: 2.5rem;
      margin-bottom: 0.5rem;
      font-weight: 800;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
    }

    .subtitle {
      font-size: 1.1rem;
      opacity: 0.95;
      font-weight: 500;
      text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
    }

    /* メインコンテンツ */
    main {
      max-width: 1200px;
      margin: 2rem auto;
      padding: 0 1rem;
    }

    .section {
      background: rgba(255, 255, 255, 0.95);
      backdrop-filter: blur(10px);
      border-radius: 20px;
      padding: 2rem;
      margin-bottom: 2rem;
      box-shadow: 0 8px 32px rgba(31, 38, 135, 0.15);
      border: 1px solid rgba(255, 255, 255, 0.5);
    }

    .section h2 {
      font-size: 1.75rem;
      background: linear-gradient(135deg, #FF6B6B 0%, #FFD93D 50%, #4D96FF 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 1.5rem;
      font-weight: 800;
      display: flex;
      align-items: center;
      gap: 0.5rem;
      animation: rainbowText 3s ease infinite;
    }

    @keyframes rainbowText {
      0%, 100% { filter: hue-rotate(0deg); }
      50% { filter: hue-rotate(30deg); }
    }

    /* 主要指標カード */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2rem;
    }

    .stat-card {
      background: linear-gradient(135deg, #FFFFFF 0%, #FFF9F0 100%);
      border-radius: 20px;
      padding: 2rem;
      text-align: center;
      box-shadow: 0 8px 25px rgba(255, 105, 180, 0.3);
      border: 3px solid transparent;
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      position: relative;
      overflow: hidden;
    }

    .stat-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
      transition: left 0.5s;
    }

    .stat-card:hover::before {
      left: 100%;
    }

    .stat-card:hover {
      transform: translateY(-8px) scale(1.03);
      box-shadow: 0 12px 40px rgba(255, 105, 180, 0.5);
    }

    .stat-card.highlight {
      border: 3px solid transparent;
      background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
      box-shadow: 0 8px 30px rgba(255, 215, 0, 0.6);
      animation: pulseGlow 2s ease-in-out infinite;
    }

    @keyframes pulseGlow {
      0%, 100% { box-shadow: 0 8px 30px rgba(255, 215, 0, 0.6); }
      50% { box-shadow: 0 8px 40px rgba(255, 215, 0, 0.9); }
    }

    .stat-label {
      font-size: 0.95rem;
      color: #7f8c8d;
      font-weight: 600;
      margin-bottom: 0.75rem;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .stat-value {
      font-size: 3rem;
      font-weight: 800;
      background: linear-gradient(135deg, #FF6B6B 0%, #FFD93D 50%, #4D96FF 100%);
      background-size: 200% 200%;
      animation: rainbowValue 3s ease infinite;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.5rem;
      text-shadow: 0 0 20px rgba(255, 215, 0, 0.3);
    }

    @keyframes rainbowValue {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .stat-card.highlight .stat-value {
      background: linear-gradient(135deg, #FF1493 0%, #FF6347 50%, #FF8C00 100%);
      background-size: 200% 200%;
      animation: goldValue 2s ease infinite;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 10px rgba(255, 215, 0, 0.8));
    }

    @keyframes goldValue {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    .stat-subtext {
      font-size: 0.9rem;
      color: #95a5a6;
      font-weight: 600;
    }

    /* 券種別成績テーブル */
    .tickets-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 1rem;
    }

    .tickets-table th,
    .tickets-table td {
      padding: 1rem;
      text-align: left;
      border-bottom: 2px solid #ecf0f1;
    }

    .tickets-table th {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      font-size: 0.9rem;
    }

    .tickets-table tr:hover {
      background: #f8f9fa;
    }

    .tickets-table td {
      font-size: 1.1rem;
      font-weight: 600;
      color: #2C3E50;
    }

    .rate-cell {
      font-size: 1.5rem;
      font-weight: 800;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* 競馬場別成績カード */
    .venue-stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.5rem;
    }

    .venue-stat-card {
      background: linear-gradient(135deg, #FFFFFF 0%, #FFF5F5 100%);
      border-radius: 20px;
      padding: 1.5rem;
      box-shadow: 0 8px 25px rgba(255, 105, 180, 0.3);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      border: 3px solid;
      position: relative;
      overflow: hidden;
    }

    .venue-stat-card::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(255,255,255,0.3) 0%, transparent 70%);
      animation: rotateGlow 4s linear infinite;
    }

    @keyframes rotateGlow {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }

    .venue-stat-card:hover {
      transform: translateY(-8px) scale(1.03) rotate(1deg);
      box-shadow: 0 12px 40px rgba(255, 105, 180, 0.5);
    }

    .venue-name {
      font-size: 1.5rem;
      font-weight: 800;
      margin-bottom: 1rem;
      background: linear-gradient(135deg, #FF6B6B 0%, #FFD93D 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      position: relative;
      z-index: 1;
    }

    .venue-stat-row {
      display: flex;
      justify-content: space-between;
      margin-bottom: 0.75rem;
      padding: 0.75rem;
      background: rgba(255, 255, 255, 0.7);
      border-radius: 12px;
      transition: all 0.3s ease;
      position: relative;
      z-index: 1;
    }

    .venue-stat-row:hover {
      background: rgba(255, 215, 0, 0.2);
      transform: translateX(5px);
    }

    .venue-stat-row:last-child {
      border-bottom: none;
    }

    .venue-stat-label {
      font-size: 0.95rem;
      color: #555;
      font-weight: 700;
    }

    .venue-stat-value {
      font-size: 1.25rem;
      font-weight: 800;
      background: linear-gradient(135deg, #FF1493 0%, #FF6347 50%, #FFA500 100%);
      background-size: 200% 200%;
      animation: rainbowValue 3s ease infinite;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* データ更新日時 */
    .updated-at {
      text-align: center;
      color: #7f8c8d;
      font-size: 0.9rem;
      margin-top: 1rem;
      font-weight: 600;
    }

    /* フッター */
    footer {
      background: linear-gradient(135deg, #FF6B6B 0%, #FFD93D 25%, #6BCB77 50%, #4D96FF 75%, #9B59B6 100%);
      background-size: 200% 200%;
      animation: footerGradient 10s ease infinite;
      color: white;
      text-align: center;
      padding: 3rem 1rem;
      margin-top: 3rem;
      box-shadow: 0 -8px 32px rgba(255, 215, 0, 0.5);
      position: relative;
      overflow: hidden;
    }

    @keyframes footerGradient {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }

    footer::before {
      content: '🏆';
      position: absolute;
      font-size: 10rem;
      opacity: 0.1;
      left: 10%;
      top: 50%;
      transform: translateY(-50%);
      animation: bounce 3s ease-in-out infinite;
    }

    footer::after {
      content: '💰';
      position: absolute;
      font-size: 8rem;
      opacity: 0.1;
      right: 10%;
      top: 50%;
      transform: translateY(-50%);
      animation: bounce 3s ease-in-out infinite 0.5s;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(-50%) scale(1); }
      50% { transform: translateY(-60%) scale(1.1); }
    }

    footer p {
      font-size: 1rem;
      opacity: 0.95;
      margin: 0.75rem 0;
      font-weight: 600;
      text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
      position: relative;
      z-index: 1;
    }

    footer a {
      color: #FFD700;
      text-decoration: underline;
      font-weight: 700;
      transition: all 0.3s ease;
      text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
    }

    footer a:hover {
      color: #FFF;
      text-shadow: 0 0 20px rgba(255, 215, 0, 1);
      transform: scale(1.05);
    }

    /* モバイル対応 */
    @media (max-width: 768px) {
      h1 {
        font-size: 1.75rem;
      }

      header {
        padding: 2rem 1rem;
      }

      .section {
        padding: 1.5rem;
      }

      .stats-grid {
        grid-template-columns: 1fr;
      }

      .stat-value {
        font-size: 2.5rem;
      }

      .tickets-table {
        font-size: 0.9rem;
      }

      .tickets-table th,
      .tickets-table td {
        padding: 0.75rem 0.5rem;
      }
    }
  </style>
</head>

<body>
  <header>
    <div class="header-content">
      <h1>📊 馬単予想成績統計</h1>
      <p class="subtitle">KEIBA Intelligence - 南関競馬 馬単的中率45.2%・回収率339.2%</p>
    </div>
  </header>

  <main>
    {stats ? (
      <>
        <!-- 総合成績 -->
        <section class="section">
          <h2>🎯 馬単予想 総合成績</h2>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-label">🏇 総レース数</div>
              <div class="stat-value">{stats.totalRaces}</div>
              <div class="stat-subtext">R</div>
            </div>

            <div class="stat-card highlight">
              <div class="stat-label">🎯 馬単的中率</div>
              <div class="stat-value">{stats.tickets.umatan.rate}</div>
              <div class="stat-subtext">%</div>
            </div>

            <div class="stat-card highlight">
              <div class="stat-label">💰 馬単回収率</div>
              <div class="stat-value">{stats.recovery.recoveryRate}</div>
              <div class="stat-subtext">%</div>
            </div>

            <div class="stat-card">
              <div class="stat-label">🏆 本命複勝率</div>
              <div class="stat-value">{stats.honmei.inMoneyRate}</div>
              <div class="stat-subtext">%（参考）</div>
            </div>
          </div>

          <div class="updated-at">
            最終更新: {formatDateTime(stats.generatedAt)}
          </div>
        </section>

        <!-- 馬単詳細成績 -->
        <section class="section">
          <h2>🎫 馬単詳細成績</h2>
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-label">✅ 馬単的中</div>
              <div class="stat-value">{stats.tickets.umatan.hit}</div>
              <div class="stat-subtext">R</div>
            </div>

            <div class="stat-card">
              <div class="stat-label">❌ 馬単不的中</div>
              <div class="stat-value">{stats.tickets.umatan.total - stats.tickets.umatan.hit}</div>
              <div class="stat-subtext">R</div>
            </div>

            <div class="stat-card highlight">
              <div class="stat-label">📈 馬単的中率</div>
              <div class="stat-value">{stats.tickets.umatan.rate}</div>
              <div class="stat-subtext">%</div>
            </div>

            <div class="stat-card">
              <div class="stat-label">💸 馬単総投資額</div>
              <div class="stat-value">{(stats.recovery.totalBet / 10000).toFixed(1)}</div>
              <div class="stat-subtext">万円</div>
            </div>

            <div class="stat-card">
              <div class="stat-label">💵 馬単総払戻</div>
              <div class="stat-value">{(stats.recovery.totalReturn / 10000).toFixed(1)}</div>
              <div class="stat-subtext">万円</div>
            </div>

            <div class="stat-card highlight">
              <div class="stat-label">🎉 馬単利益</div>
              <div class="stat-value">{((stats.recovery.totalReturn - stats.recovery.totalBet) / 10000).toFixed(1)}</div>
              <div class="stat-subtext">万円</div>
            </div>
          </div>
        </section>

        <!-- 競馬場別成績 -->
        <section class="section">
          <h2>🏇 競馬場別 馬単成績</h2>
          <div class="venue-stats-grid">
            {Object.entries(stats.venues).map(([venueName, venueData]: [string, any]) => {
              const venueColors = {
                '大井': '#FF6B6B',
                '川崎': '#45B7D1',
                '船橋': '#4ECDC4',
                '浦和': '#A770EF'
              };
              const venueEmojis = {
                '大井': '🌃',
                '川崎': '🌉',
                '船橋': '⚓',
                '浦和': '🌸'
              };
              const color = venueColors[venueName as keyof typeof venueColors] || '#667eea';
              const emoji = venueEmojis[venueName as keyof typeof venueEmojis] || '🏇';

              return (
                <div class="venue-stat-card" style={`border-color: ${color};`}>
                  <div class="venue-name">{emoji} {venueName}競馬場</div>
                  <div class="venue-stat-row">
                    <span class="venue-stat-label">🏇 総レース数</span>
                    <span class="venue-stat-value">{venueData.totalRaces}R</span>
                  </div>
                  <div class="venue-stat-row">
                    <span class="venue-stat-label">💰 馬単回収率</span>
                    <span class="venue-stat-value">{venueData.recoveryRate}%</span>
                  </div>
                  <div class="venue-stat-row">
                    <span class="venue-stat-label">🏆 本命複勝率</span>
                    <span class="venue-stat-value">{venueData.winRate}%</span>
                  </div>
                </div>
              );
            })}
          </div>
        </section>

      </>
    ) : (
      <section class="section">
        <p style="text-align: center; font-size: 1.2rem; color: #7f8c8d;">
          統計データを読み込めませんでした。<br />
          <code>npm run calc-stats</code> を実行してください。
        </p>
      </section>
    )}
  </main>

  <footer>
    <p>📊 KEIBA Intelligence 予想成績統計</p>
    <p>
      <a href="https://keiba-intelligence.jp/" target="_blank" rel="noopener noreferrer">
        KEIBA Intelligence で AI予想を見る →
      </a>
    </p>
    <p><a href="/" style="color: white;">← トップページに戻る</a></p>
    <p style="margin-top: 1rem; font-size: 0.85rem;">&copy; 2026 All rights reserved</p>
  </footer>
</body>
</html>
